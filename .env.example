# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "https://your-frontend-domain.vercel.app"]
CORS_CREDENTIALS=true

# Data Directory
DATA_DIR=data

# Frontend URL (for production CORS)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Logging
LOG_LEVEL=INFO
